rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only allow access to specific collections used by the app
    match /cargos/{cargoId} {
      allow read: if true;
      allow write: if true; // Required since the app writes via client SDK (store.tsx)
    }
    
    match /bids/{bidId} {
      allow read: if true;
      allow write: if true; // Required since the app writes via client SDK (store.tsx)
    }
    
    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
